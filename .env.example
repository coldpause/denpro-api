# PostgreSQL connection string (Supabase pooler URL)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# JWT secrets — use long random strings
JWT_SECRET=change_me_random_secret
JWT_REFRESH_SECRET=change_me_random_refresh_secret

# Port (Railway sets this automatically)
PORT=4000

NODE_ENV=production
